# ── Database ──────────────────────────────────────────────────────────────────
# Use Neon, Supabase, or Railway for a hosted Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED in production.
API_SECRET=

# ── S3-compatible bucket ──────────────────────────────────────────────────────
# Cloudflare R2 example:
BUCKET_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BUCKET_REGION=auto
BUCKET_ACCESS_KEY=
BUCKET_SECRET_KEY=
BUCKET_NAME=recordings

# AWS S3 example (omit BUCKET_ENDPOINT to use standard AWS endpoint):
# BUCKET_REGION=us-east-1
# BUCKET_ACCESS_KEY=AKIA...
# BUCKET_SECRET_KEY=...
# BUCKET_NAME=recordings

# ── Transcription ─────────────────────────────────────────────────────────────
# OpenAI API key for Whisper transcription. Leave blank to skip transcription.
OPENAI_API_KEY=
